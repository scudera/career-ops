# Personal data (user fills these)
cv.md
data/applications.md
data/pipeline.md
data/scan-history.tsv
data/parser-output/**/*.json
!data/parser-output/.gitkeep
!data/parser-output/**/.gitkeep
reports/*.md
!reports/.gitkeep
output/*
!output/.gitkeep
batch/logs/*
!batch/logs/.gitkeep
batch/batch-state.tsv
batch/batch-input.tsv
batch/tracker-additions/**/*.tsv
!batch/tracker-additions/.gitkeep
jds/*
!jds/.gitkeep

# Writing samples (user's personal files — never committed)
writing-samples/*
!writing-samples/README.md

# User config and customization (never auto-updated)
config/profile.yml
portals.yml
modes/_profile.md
.update-dismissed
.update-lock

# Secrets (never commit — use .env.example as template)
.env

# Generated
.resolved-prompt-*
node_modules/
bun.lock

# OS
.DS_Store
*.mov
*.mp4

# Claude Code local
.claude/settings.local.json
.claude/memory/
career-dashboard
package-lock.json

# Personal data — root only (added 2026-05-22)
# Use leading slash to NOT match examples/ templates from upstream
/cv.md
/cv-en.md
/cv-pt.md
/config/profile.yml
/config/profile.yaml
/article-digest.md

# Master profile (real personal data, NEVER commit)
# Template lives in templates/master-profile.example.md (committed)
/docs/resume/master-profile.md
# Generated variants from master profile
/docs/resume/cv-*.md
/cv-eu.md
/cv-uk.md
/cv-ie.md
/cv-br.md
/cv-us.md

# Generated personal artifacts (any path matches output/)
/output/cover-letter-*.md
